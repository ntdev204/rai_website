# Database
POSTGRES_DB=robot_dashboard
POSTGRES_USER=robot_admin
POSTGRES_PASSWORD=securepassword
DATABASE_URL=postgresql+asyncpg://robot_admin:securepassword@postgres:5432/robot_dashboard

# Auth
JWT_SECRET=supersecretkey_change_in_production
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_DAYS=7
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123

# ZMQ (SCADA Bridge on RasPi)
# When running backend on a laptop, prefer Tailscale host(s)
ZMQ_SCADA_HOST=100.120.77.81
ZMQ_SCADA_HOSTS=100.120.77.81
ZMQ_CMD_PORT=5555
ZMQ_TELEMETRY_PORT=5556
ZMQ_CAMERA_PORT=5557

# Jetson AI API
JETSON_API_URL=http://100.116.161.125:8080

# Face authentication
FACE_MATCH_THRESHOLD=0.78
FACE_AUTH_SHARED_SECRET=
FACE_DATA_DIR=/app/data/faces
FACE_MIN_IMAGES=8
FACE_MAX_IMAGES=20

# Client
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
